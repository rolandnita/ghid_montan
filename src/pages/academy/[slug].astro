---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Badge from '../../components/Badge.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/config';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.data.slug || article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const { title, category, publishedAt, readingTime, image, excerpt } = article.data;
const slug = article.data.slug || article.id;

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.data.category === category && (a.data.slug || a.id) !== slug)
  .slice(0, 3);
---

<BaseLayout
  title={title}
  description={excerpt}
  currentPath={`/academy/${slug}`}
>
  <!-- Hero Image -->
  <div class="relative h-96 md:h-[500px] w-full overflow-hidden mountain-fog">
    <img src={image} alt={title} class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-slate-950"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <!-- Article Header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <Badge text={category} color="info" />
        <span class="text-slate-400 text-sm">•</span>
        <span class="text-slate-400">{readingTime} min read</span>
      </div>

      <h1 class="text-5xl md:text-6xl font-bold text-slate-100 mb-6">{title}</h1>

      <div class="flex items-center justify-between pb-6 border-b border-slate-800/50">
        <div>
          <p class="text-slate-400 text-sm">Publicat pe</p>
          <p class="text-slate-200 font-semibold">{formatDate(publishedAt)}</p>
        </div>
        <p class="text-slate-400 text-sm">de Alexandru Cristian</p>
      </div>
    </header>

    <!-- Article Content -->
    <article class="prose prose-invert max-w-none mb-20">
      <div class="text-lg text-slate-300 leading-relaxed space-y-6">
        <Content />
      </div>
    </article>

    <!-- Author Bio -->
    <div class="glass p-8 rounded-xl mb-20">
      <div class="flex items-start gap-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-amber-600 to-amber-500 flex-shrink-0 flex items-center justify-center text-2xl">
          👨‍🏫
        </div>
        <div>
          <h3 class="text-xl font-bold text-slate-100 mb-2">Despre Autor</h3>
          <p class="text-slate-400 mb-4">
            Alexandru Cristian este ghid de munte certificat cu peste 15 ani de experiență în alpinism,
            navigație montană și instruire în medii extreme. Passionate despre a partaja cunoștințele sale
            și a ajuta alpiniștii de orice nivel să se dezvolte.
          </p>
          <Button href="/about" variant="ghost" size="sm">Citește biografia completa →</Button>
        </div>
      </div>
    </div>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="border-t border-slate-800/50 pt-20">
        <h2 class="text-3xl font-bold text-slate-100 mb-8">Articole Asemănătoare</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedArticles.map((relArticle) => (
            <a href={`/academy/${relArticle.data.slug}`} class="group glass-hover rounded-xl overflow-hidden">
              <img
                src={relArticle.data.image}
                alt={relArticle.data.title}
                class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-300"
              />
              <div class="p-6">
                <Badge text={relArticle.data.category} color="info" />
                <h3 class="text-lg font-bold text-slate-100 mt-4 mb-2 group-hover:text-amber-400 transition-colors line-clamp-2">
                  {relArticle.data.title}
                </h3>
                <p class="text-slate-400 text-sm">{relArticle.data.readingTime} min read</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <CTASection
    title="Ai mai multe întrebări?"
    description="Doresc să aflu mai mult despre alpinism, echipament sau tururi personalizate? Contactează-mă direct."
    ctaText="Trimite-mi un mesaj"
    ctaHref="/contact"
  />
</BaseLayout>

<style>
  /* Custom prose styles for better dark mode appearance */
  :global(.prose) {
    --tw-prose-body: #cbd5e1;
    --tw-prose-headings: #f1f5f9;
    --tw-prose-links: #fbbf24;
    --tw-prose-code: #fbbf24;
    --tw-prose-pre-bg: #1e293b;
    --tw-prose-tables: #cbd5e1;
  }

  :global(.prose h2) {
    @apply text-3xl font-bold mt-12 mb-4 text-slate-100;
  }

  :global(.prose h3) {
    @apply text-2xl font-bold mt-8 mb-3 text-slate-100;
  }

  :global(.prose p) {
    @apply mb-4 text-slate-300;
  }

  :global(.prose ul),
  :global(.prose ol) {
    @apply mb-4 text-slate-300 pl-6;
  }

  :global(.prose li) {
    @apply mb-2;
  }

  :global(.prose strong) {
    @apply text-slate-100 font-bold;
  }

  :global(.prose code) {
    @apply bg-slate-900/50 px-2 py-1 rounded text-amber-400 font-mono text-sm;
  }

  :global(.prose pre) {
    @apply bg-slate-900 p-4 rounded-lg overflow-x-auto;
  }

  :global(.prose blockquote) {
    @apply border-l-4 border-amber-500 pl-4 italic text-slate-300 my-4;
  }
</style>
