---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { href, variant = 'primary', size = 'md', className = '', ...rest } = Astro.props;

const variants = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  ghost: 'btn-ghost',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3',
  lg: 'px-8 py-4 text-lg',
};
---

<a href={href} class={`${variants[variant]} ${sizes[size]} ${className} inline-block`} {...rest}>
  <slot />
</a>
