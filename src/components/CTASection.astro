---
import Button from './Button.astro';

interface Props {
  title: string;
  description: string;
  ctaText?: string;
  ctaHref?: string;
  className?: string;
}

const {
  title,
  description,
  ctaText = 'Contactează-mă',
  ctaHref = '/contact',
  className = '',
} = Astro.props;
---

<section class={`relative py-20 overflow-hidden ${className}`}>
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-amber-600/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-cyan-600/5 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
      {title}
    </h2>
    <p class="text-xl text-slate-400 mb-8 max-w-2xl mx-auto">
      {description}
    </p>

    <Button href={ctaHref} variant="primary" size="lg">
      {ctaText}
    </Button>
  </div>
</section>
